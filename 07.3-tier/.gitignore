# Terraform local state files
*.tfstate
*.tfstate.*

# Terraform crash log files
crash.log

# Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Terraform CLI configuration files
.terraformrc
terraform.rc

# Terraform directory
.terraform/

# Terraform lock file (optional – some teams commit it)
.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive variable files
secrets.tfvars